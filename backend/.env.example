# Datenbank
# SQLite (lokal): sqlite:///./kr_control.db
# MySQL (Railway/Produktion): mysql+pymysql://user:password@host:3306/dbname
DATABASE_URL=sqlite:///./kr_control.db

# JWT Security
# WICHTIG: In Produktion durch zufälligen langen String ersetzen!
# Generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Token-Gültigkeit in Minuten (1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Erster Admin-User (wird beim ersten Start angelegt, falls keine User vorhanden)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@kr-control.de
FIRST_ADMIN_PASSWORD=ChangeMe123!

# Standard-Widerruf-Fenster in Stunden
DEFAULT_RECALL_HOURS=24

# SMTP / E-Mail
SMTP_HOST=w013a015.kasserver.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=krcontrol@nickkrakow.de
SMTP_PASSWORD=dein-passwort-hier
SMTP_FROM=krcontrol@nickkrakow.de
SMTP_FROM_NAME=KR Control

# Frontend-URL (für Links in E-Mails)
FRONTEND_URL=https://kr-control-production.up.railway.app
